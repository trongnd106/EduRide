# =============================================================
# File cấu hình môi trường Production cho VPS
# =============================================================

# Docker Hub Username
DOCKERHUB_USERNAME=your_dockerhub_username

# Application
APP_NAME=hust
APP_ENV=production
APP_KEY=base64:your_app_key_here
APP_DEBUG=false
APP_URL=http://34.61.124.56

# Ports
APP_PORT=80
DB_EXPOSE_PORT=3306
REDIS_EXPOSE_PORT=6379
ADMINER_PORT=8001

# Database
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=hust_db
DB_USERNAME=hust_user
DB_PASSWORD=your_secure_password
DB_ROOT_PASSWORD=your_root_password

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

L5_SWAGGER_CONST_HOST=
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_USE_ABSOLUTE_PATH=true
ASSET_URL=
FORCE_HTTPS=false
